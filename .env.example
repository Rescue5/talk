# Публичный адрес local web-app. 127.0.0.1 не открывает сервис в локальную сеть.
APP_HOST=127.0.0.1
APP_PORT=8080

# Каталог на хосте монтируется read-only и не входит в image.
# Приложение запускается и с пустым каталогом, показывая model_unavailable.
MODEL_DIR=/absolute/path/to/model-directory
TALC_CHECKPOINT_FILE=talc.pt
SULFIDE_CHECKPOINT_FILE=sulfide.pt
SULFIDE_SAM_CHECKPOINT_FILE=mobile_sam.pt

# CPU работает на любом поддерживаемом Docker-хосте.
MODEL_DEVICE=cpu
SULFIDE_SAM_DEVICE=auto
CV_NUM_THREADS=8

# Необязательные настройки.
MAX_UPLOAD_BYTES=536870912
CHOKIDAR_USEPOLLING=false
